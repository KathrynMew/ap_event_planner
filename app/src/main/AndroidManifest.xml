<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/komosforge_icon"
        android:label="@string/app_name"
        android:roundIcon="@drawable/komosforge_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.Project_4_Event_Planner"
        tools:targetApi="31">
        <receiver
            android:name=".BroadcastReceiverPassword"
            android:enabled="true"
            android:exported="true" />

        <activity
            android:name=".Profiles"
            android:exported="true" />
        <activity
            android:name=".EditEvent"
            android:exported="true" />
        <activity
            android:name=".Groups"
            android:exported="true" />
        <activity
            android:name=".AddFriends"
            android:exported="true" />
        <activity
            android:name=".FriendRequests"
            android:exported="true" />
        <activity
            android:name=".Friends"
            android:exported="true" />
        <activity
            android:name=".CreateGroup"
            android:exported="true" />
        <activity
            android:name=".CreateEvent"
            android:exported="true" />
        <activity
            android:name=".Events"
            android:exported="true" />
        <activity
            android:name=".UserRegistration"
            android:exported="true" />
        <activity
            android:name=".Login"
            android:exported="true" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>