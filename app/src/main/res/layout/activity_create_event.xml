<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/layout_background"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    tools:context=".CreateEvent">

    <TextView
        style="@style/ScreenTitle"
        android:text="create event"
        android:paddingVertical="5dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="?android:attr/listDivider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                style="@style/sectionHeader"
                android:text="name" />

            <EditText
                android:id="@+id/editEventName"
                style="@style/user_input_text"
                android:hint="Enter Event Name"
                android:imeOptions="actionDone"/>

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                style="@style/sectionHeader"
                android:letterSpacing="0.3"
                android:text="select a date" />

            <TextView
                android:id="@+id/eventDateDialog"
                style="@style/user_select_date"
                android:clickable="true"
                android:hint="MM/DD/YYYY" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:letterSpacing="0.5"
                android:text="event tag"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/gold_shadow"
                android:textSize="20sp" />

            <RadioGroup
                android:id="@+id/relationTypeRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/ui_field_background"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radiobuttonPersonal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/lexend_medium"
                    android:text="Personal"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/radiobuttonCasual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/lexend_medium"
                    android:text="Casual"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/radiobuttonWork"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/lexend_medium"
                    android:text="Work"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/radiobuttonSchool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/lexend_medium"
                    android:text="School"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/radiobuttonOnline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/lexend_medium"
                    android:text="Online"
                    android:textSize="13sp" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="?android:attr/listDivider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/checkboxOther"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend_medium"
                    android:text="Group:" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="wrap_content" />

                <Spinner
                    android:id="@+id/displayGroupsSpinner"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@color/ui_field_background"
                    android:spinnerMode="dropdown"
                    android:textAlignment="center" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="?android:attr/listDivider" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                android:id="@+id/inviteesHeader"
                style="@style/sectionHeader"
                android:letterSpacing="0.2"
                android:text="select attendees" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewInvitees"
                android:layout_width="300dp"
                android:layout_height="150dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:letterSpacing="0.5"
                android:text="who is busy?"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/gold_shadow"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/noResultsCreateEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend_medium"
                android:layout_margin="10dp"
                android:padding="5dp"
                android:background="@color/ui_field_background"
                android:textSize="16sp"
                android:textAlignment="center"
                android:elevation="10dp"
                android:textColor="@color/available_background"
                android:text="Looks like we're all free!"
                android:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAvailable"
                android:layout_width="match_parent"
                android:layout_height="200dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                style="@style/sectionHeader"
                android:letterSpacing="0.5"
                android:text="start time" />

            <TextView
                android:id="@+id/eventStartDialog"
                android:layout_width="300dp"
                android:layout_height="50dp"
                android:background="@color/ui_field_background"
                android:clickable="true"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:hint="00:00 AM"
                android:textAlignment="center"
                android:textColor="@color/tyrian_purple"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/showStartTime"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:background="#257129"
                android:fontFamily="@font/lexend_medium"
                android:textAlignment="center"
                android:textColor="@color/ui_field_background" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                style="@style/sectionHeader"
                android:letterSpacing="0.5"
                android:text="end time" />

            <TextView
                android:id="@+id/eventEndDialog"
                android:layout_width="300dp"
                android:layout_height="50dp"
                android:background="@color/ui_field_background"
                android:clickable="true"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:hint="00:00 AM"
                android:textAlignment="center"
                android:textColor="@color/tyrian_purple"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/showEndTime"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:background="#257129"
                android:fontFamily="@font/lexend_medium"
                android:textAlignment="center"
                android:textColor="@color/ui_field_background" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                style="@style/sectionHeader"
                android:letterSpacing="0.5"
                android:text="Location" />

            <EditText
                android:id="@+id/editLocation"
                style="@style/user_input_text"
                android:hint="(Optional)"
                android:text=""
                android:imeOptions="actionDone"/>

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                style="@style/sectionHeader"
                android:letterSpacing="0.2"
                android:text="advisory notes" />

            <EditText
                android:id="@+id/editAdvisoryNotes"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:background="@color/ui_field_background"
                android:fontFamily="@font/lexend_medium"
                android:gravity="start|top"
                android:hint="Anything guests should know?\ni.e. dress code, budget, transportation, medical precautions. Can include links!"
                android:includeFontPadding="true"
                android:inputType="textMultiLine"
                android:isScrollContainer="true"
                android:maxHeight="200dp"
                android:minHeight="50dp"
                android:padding="5dp"
                android:textColor="@color/tyrian_purple"
                android:imeOptions="actionDone"/>

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <FrameLayout
                android:id="@+id/fragmentContainerViewAlarm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="?android:attr/listDivider" />

    <Button
        android:id="@+id/buttonCreateEvent"
        style="@style/navigationButtonStyle"
        android:text="Create"
        android:layout_marginVertical="10dp"
        app:cornerRadius="1dp" />

</LinearLayout>