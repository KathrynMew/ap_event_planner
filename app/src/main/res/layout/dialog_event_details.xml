<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/view_event_details"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:background="@color/layout_background"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/editEventNameDisplay"
        android:text="Event Name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:letterSpacing="0.4"
        android:paddingVertical="5dp"
        android:textAlignment="center"
        android:textAllCaps="true"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@color/ui_field_background"
        android:shadowColor="@color/gold_shadow"
        android:shadowRadius="20"
        android:textColor="@color/tyrian_purple"
        android:fontFamily="@font/lexend_medium" />

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="?android:attr/listDivider" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="?android:attr/listDivider"
        android:background="@color/ui_field_background"
        android:showDividers="middle"
        android:stretchColumns="1">

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="?android:attr/listDivider"
            android:minHeight="25dp"
            android:showDividers="middle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="0"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:shadowColor="@color/gold_shadow"
                android:shadowRadius="13"
                android:text="Type"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/school_text"
                android:textSize="14sp" />


            <TextView
                android:id="@+id/editEventTypeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="1"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center_vertical"
                android:paddingHorizontal="5dp"
                android:text="TextView"
                android:textColor="@color/tyrian_purple" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="?android:attr/listDivider"
            android:minHeight="25dp"
            android:showDividers="middle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="0"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:shadowColor="@color/gold_shadow"
                android:shadowRadius="13"
                android:text="Date"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/school_text"
                android:textSize="14sp" />


            <TextView
                android:id="@+id/editEventDateDisplay"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="1"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center_vertical"
                android:paddingHorizontal="5dp"
                android:text="Month day, year"
                android:textColor="@color/tyrian_purple" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="?android:attr/listDivider"
            android:minHeight="25dp"
            android:showDividers="middle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="0"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:shadowColor="@color/gold_shadow"
                android:shadowRadius="13"
                android:text="Start time"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/school_text"
                android:textSize="14sp" />


            <TextView
                android:id="@+id/editStartTimeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="1"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center_vertical"
                android:paddingHorizontal="5dp"
                android:text="Time"
                android:textColor="@color/tyrian_purple" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="?android:attr/listDivider"
            android:minHeight="25dp"
            android:showDividers="middle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="0"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:shadowColor="@color/gold_shadow"
                android:shadowRadius="13"
                android:text="End Time"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/school_text"
                android:textSize="14sp" />


            <TextView
                android:id="@+id/editEndTimeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="1"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center_vertical"
                android:paddingHorizontal="5dp"
                android:text="Time"
                android:textColor="@color/tyrian_purple" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="?android:attr/listDivider"
            android:minHeight="25dp"
            android:showDividers="middle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="0"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:shadowColor="@color/gold_shadow"
                android:shadowRadius="13"
                android:text="Organizer"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/school_text"
                android:textSize="14sp" />


            <TextView
                android:id="@+id/editEventCreatorDisplay"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="1"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center_vertical"
                android:paddingHorizontal="5dp"
                android:text="Name"
                android:textColor="@color/tyrian_purple" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="?android:attr/listDivider"
            android:minHeight="25dp"
            android:showDividers="middle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="0"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:shadowColor="@color/gold_shadow"
                android:shadowRadius="13"
                android:text="Invitees"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/school_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/editEventInvitedDisplay"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="1"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center_vertical"
                android:paddingHorizontal="5dp"
                android:text="Full Name 1\nFull Name 2\nFull Name 3"
                android:textColor="@color/tyrian_purple" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="?android:attr/listDivider"
            android:minHeight="25dp"
            android:showDividers="middle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="0"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:shadowColor="@color/gold_shadow"
                android:shadowRadius="13"
                android:text="location"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/school_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/editEventLocationDisplay"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="1"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center_vertical"
                android:maxWidth="1dp"
                android:paddingHorizontal="5dp"
                android:text="TestAddressorlinklinetoseewidthadjustments"
                android:textColor="@color/tyrian_purple" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="?android:attr/listDivider"
            android:minHeight="25dp"
            android:showDividers="middle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="0"
                android:background="@color/tyrian_purple"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center"
                android:paddingHorizontal="5dp"
                android:shadowColor="@color/gold_shadow"
                android:shadowRadius="13"
                android:text="Advisory"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:textColor="@color/school_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/editEventNoteDisplay"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_column="1"
                android:fontFamily="@font/lexend_medium"
                android:gravity="center_vertical"
                android:maxWidth="1dp"
                android:paddingHorizontal="5dp"
                android:text="This is a practice note that should be giiberish"
                android:textColor="@color/tyrian_purple" />
        </TableRow>
    </TableLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="?android:attr/listDivider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ui_field_background"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonBackToEvents"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:drawableTop="@drawable/sharp_arrow_left_alt_24"
            android:fontFamily="@font/lexend_medium"
            android:text="Back"
            android:textColor="@color/tyrian_purple"
            android:textSize="12sp" />

        <Button
            android:id="@+id/buttonEditEvent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:drawableTop="@drawable/edit_event_icon"
            android:fontFamily="@font/lexend_medium"
            android:text="Edit Event"
            android:textColor="@color/tyrian_purple"
            android:textSize="12sp" />

        <Button
            android:id="@+id/buttonEventDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:drawableTop="@drawable/sharp_delete_24"
            android:fontFamily="@font/lexend_medium"
            android:text="Delete Event"
            android:textColor="@color/tyrian_purple"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>