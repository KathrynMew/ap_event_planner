<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/ui_field_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" >

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="?android:attr/listDivider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/searchResultText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.4"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:background="#2B450D"
            android:fontFamily="@font/lexend_medium"
            android:lineSpacingExtra="2dp"
            android:padding="10dp"
            android:shadowColor="@color/gold_shadow"
            android:shadowRadius="15"
            android:text="Cameron Peterson\n@TheBlender"
            android:textAlignment="viewStart"
            android:textColor="@color/school_text"
            android:textSize="15sp" />

        <Button
            android:id="@+id/buttonAddPerson"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#00FFFFFF"
            android:fontFamily="@font/lexend_medium"
            android:shadowColor="#35FF00"
            android:shadowRadius="20"
            android:text="Add"
            android:textAllCaps="true"
            android:textColor="@color/available_background"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="visible"/>

        <Button
            android:id="@+id/buttonCancelRequest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#00FFFFFF"
            android:fontFamily="@font/lexend_medium"
            android:shadowColor="#B5ADAD"
            android:shadowRadius="20"
            android:text="Cancel"
            android:textAllCaps="true"
            android:textColor="#837F7F"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="?android:attr/listDivider" />

</LinearLayout>