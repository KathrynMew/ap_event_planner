<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/ui_field_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" >

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="?android:attr/listDivider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/requesterTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="5dp"
            android:background="#000033"
            android:fontFamily="@font/lexend_medium"
            android:lineSpacingExtra="2dp"
            android:padding="10dp"
            android:shadowColor="@color/gold_shadow"
            android:shadowRadius="13"
            android:text="Kollux Apollonia\n@kollux"
            android:textAlignment="viewStart"
            android:textColor="@color/school_text"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <View
                android:id="@+id/CasualTag"
                android:layout_width="10dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#630348"
                android:visibility="visible" />

            <View
                android:id="@+id/SchoolTag"
                android:layout_width="10dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/gold_shadow"
                android:visibility="visible" />

            <View
                android:id="@+id/WorkTag"
                android:layout_width="10dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#033063"
                android:visibility="visible" />

            <View
                android:id="@+id/OnlineTag"
                android:layout_width="10dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@color/online_background"
                android:visibility="visible" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/acceptButton"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:background="@color/available_background"
            android:contentDescription="add friend"
            android:cropToPadding="true"
            android:scaleType="fitXY"
            android:scaleX="0.7"
            android:scaleY="0.45"
            android:src="@drawable/baseline_check_24" />

        <View
            android:id="@+id/divider"
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="?android:attr/listDivider" />

        <ImageButton
            android:id="@+id/denyButton"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:background="#5A0A0A"
            android:contentDescription="deny friend"
            android:scaleType="fitXY"
            android:scaleX="0.7"
            android:scaleY="0.45"
            android:src="@drawable/icon_x"
            app:tint="#FF0000" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="?android:attr/listDivider" />

</LinearLayout>