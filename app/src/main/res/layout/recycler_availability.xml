<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@color/ui_field_background"
    android:padding="8dp">

    <TextView
        android:id="@+id/textEventDuration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.4"
        android:paddingVertical="5dp"
        android:fontFamily="@font/lexend_medium"
        android:background="@color/casual_background"
        android:textColor="@color/casual_text"
        android:shadowColor="@color/gold_shadow"
        android:shadowRadius="15"
        android:textAlignment="center"
        android:text="11:00 AM\n12:00 AM"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/displayEvent"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/tyrian_purple"
        android:fontFamily="@font/lexend_medium"
        android:gravity="fill_vertical"
        android:paddingHorizontal="10dp"
        android:shadowColor="@color/gold_shadow"
        android:shadowRadius="13"
        android:text="Cameron Peterson\n@TheBlender"
        android:textColor="@color/school_text"
        android:textSize="14sp" />

    <ImageButton
        android:id="@+id/viewEventDetailsButton"
        android:layout_width="48dp"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:contentDescription="@string/state_unavailable"
        android:src="@drawable/event_note_unavailable"
        android:visibility="gone"/>

</LinearLayout>