<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ui_field_background"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/displayMonthDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/tyrian_purple"
            android:fontFamily="@font/lexend_medium"
            android:gravity="center"
            android:lineSpacingMultiplier="1.09"
            android:paddingHorizontal="15dp"
            android:paddingVertical="20dp"
            android:shadowColor="@color/gold_shadow"
            android:shadowRadius="13"
            android:text="May\n5"
            android:textColor="@color/ui_field_background"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:layout_marginStart="20dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/displayEventNameCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend_medium"
                android:text="Event Name"
                android:textColor="@color/tyrian_purple"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/displayStartEndCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend_medium"
                android:text="00:00 AM - 00:00 PM"
                android:textColor="@color/available_background"
                android:textSize="15sp" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>